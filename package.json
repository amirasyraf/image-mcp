{
  "name": "image-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI-powered image generation and editing using Google Gemini API. Designed for frontend development workflows.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "image-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
